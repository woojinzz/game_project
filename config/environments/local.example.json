{
  "environment": "local",
  "description": "로컬 개발자별 설정 (local.json으로 복사하여 사용)",
  "debug_mode": true,
  "logging": {
    "level": "DEBUG",
    "enable_console": true,
    "enable_file": true,
    "log_directory": "logs/local/"
  },
  "simulation": {
    "agent_count": 20,
    "resource_count": 30,
    "map_size": {
      "width": 50,
      "height": 30
    },
    "debug_visualization": true,
    "performance_monitoring": true
  },
  "ai_settings": {
    "decision_interval": 1.0,
    "utility_logging": true,
    "behavior_tracking": true
  },
  "ui": {
    "stats_update_interval": 0.5,
    "show_debug_info": true,
    "enable_dev_panels": true
  },
  "personal_settings": {
    "preferred_camera_zoom": 2.0,
    "auto_save_interval": 300,
    "custom_shortcuts": {
      "toggle_debug": "F1",
      "reset_simulation": "F2",
      "save_state": "F3"
    }
  },
  "api_keys": {
    "analytics_service": "YOUR_ANALYTICS_API_KEY_HERE",
    "cloud_save": "YOUR_CLOUD_SAVE_API_KEY_HERE",
    "telemetry": "YOUR_TELEMETRY_API_KEY_HERE"
  },
  "database": {
    "connection_string": "YOUR_LOCAL_DB_CONNECTION_STRING",
    "username": "YOUR_DB_USERNAME", 
    "password": "YOUR_DB_PASSWORD"
  }
}